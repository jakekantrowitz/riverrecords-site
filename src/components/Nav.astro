<style>
  .nav-cta-short { display: none; }
  @media (max-width: 1024px) {
    .nav-cta-full { display: none; }
    .nav-cta-short { display: inline; }
  }
  .mobile-menu-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    padding: 12px 18px 4px;
  }
</style>

<script>
  // Hamburger toggle
  document.getElementById('nav-hamburger')?.addEventListener('click', () => {
    document.getElementById('mobileMenu')?.classList.toggle('open');
  });
  document.querySelectorAll('.mobile-menu-link').forEach(link => {
    link.addEventListener('click', () => {
      document.getElementById('mobileMenu')?.classList.remove('open');
    });
  });

  // Specialties dropdown
  const dropdown = document.getElementById('specialties-dropdown');
  dropdown?.querySelector('.nav-dropdown-toggle')?.addEventListener('click', (e) => {
    e.stopPropagation();
    dropdown.classList.toggle('open');
  });
  document.addEventListener('click', () => {
    dropdown?.classList.remove('open');
  });

  // Active nav state
  const path = window.location.pathname;
  document.querySelectorAll('.nav-links a').forEach(link => {
    if (link.getAttribute('href') === path) {
      link.classList.add('active');
    }
  });
  // Highlight dropdown toggle if on a specialty page
  if (path.startsWith('/for/')) {
    dropdown?.querySelector('.nav-dropdown-toggle')?.classList.add('active');
  }
</script>
