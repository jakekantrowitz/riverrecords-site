---
const { activeTag = '' } = Astro.props;

// Display names for tags (prettier than raw slugs)
const tagLabels: Record<string, string> = {
  'product-updates': 'Product Updates',
  'research': 'Research',
  'information-chaos': 'Information Chaos',
  'medical-documentation': 'Medical Documentation',
  'burnout': 'Burnout',
  'ai-scribe': 'AI Scribe',
  'ai-medical-scribe': 'AI Medical Scribe',
  'longitudinal-care': 'Longitudinal Care',
  'note-bloat': 'Note Bloat',
  'clinical-context': 'Clinical Context',
  'care-coordination': 'Care Coordination',
  'ai-assistant': 'AI Assistant',
  'collaborative-care': 'Collaborative Care',
  'medical-decision-making': 'Medical Decision Making',
  'medical-dictation-ai': 'Medical Dictation AI',
  'stream-by-river-records': 'Stream',
};

// Show these tags in the bar (curated order, most important first)
const displayTags = [
  'product-updates',
  'research',
  'information-chaos',
  'burnout',
  'medical-documentation',
  'ai-scribe',
  'longitudinal-care',
  'note-bloat',
  'clinical-context',
];
---
<nav class="blog-tag-bar">
  <a href="/blog" class:list={['blog-tag-pill', { active: !activeTag }]}>All</a>
  {displayTags.map((tag) => (
    <a href={`/blog/tag/${tag}`} class:list={['blog-tag-pill', { active: activeTag === tag }]}>
      {tagLabels[tag] || tag}
    </a>
  ))}
</nav>

<style>
.blog-tag-bar {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 32px;
}
.blog-tag-pill {
  font-size: 0.78rem;
  font-weight: 500;
  padding: 6px 14px;
  border-radius: var(--r-pill);
  border: 1px solid var(--border);
  background: var(--white);
  color: var(--ink-muted);
  text-decoration: none;
  transition: all 0.12s;
  white-space: nowrap;
}
.blog-tag-pill:hover {
  border-color: var(--primary);
  color: var(--primary);
}
.blog-tag-pill.active {
  background: var(--primary);
  border-color: var(--primary);
  color: var(--white);
}
</style>
