---
import Base from './Base.astro';
import OfferBanner from '../components/OfferBanner.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CtaDark from '../components/CtaDark.astro';

const { frontmatter } = Astro.props;
const title = frontmatter.seoTitle || `${frontmatter.name} — Stream by River Records`;
const description = frontmatter.seoDescription || frontmatter.description;
---
<Base title={title} description={description}>
  <OfferBanner />
  <Nav />
  <main>
    <article class="feature-page">
      <div class="container">
        <!-- Hero -->
        <div class="feature-hero">
          <a href="/features" class="feature-back">← All Features</a>
          <span class="section-label">{frontmatter.name}</span>
          <h1>{frontmatter.headline || frontmatter.name}</h1>
          {frontmatter.subheadline && <p class="feature-sub">{frontmatter.subheadline}</p>}
        </div>

        <!-- Bullets -->
        {frontmatter.bullets && frontmatter.bullets.length > 0 && (
          <div class="feature-bullets">
            {frontmatter.bullets.map((bullet: string) => (
              <div class="feature-bullet">
                <div class="proof-check"></div>
                <span>{bullet}</span>
              </div>
            ))}
          </div>
        )}

        <!-- Body -->
        <div class="feature-body">
          <slot />
        </div>

        <!-- FAQ -->
        {frontmatter.faq && frontmatter.faq.length > 0 && (
          <div class="feature-faq">
            <h2>Frequently Asked Questions</h2>
            {frontmatter.faq.map((item: { question: string; answer: string }) => (
              <div class="feature-faq-item">
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- CTA -->
      <div class="container" style="padding-top:48px;padding-bottom:88px;">
        <CtaDark secondaryHref="/book-demo" secondaryLabel="Talk to a clinician first">
          See {frontmatter.name} in action.<br><em>Start your 30-day free trial.</em>
          <Fragment slot="body">No credit card required. $149/month after trial. Works alongside any EHR.</Fragment>
        </CtaDark>
      </div>
    </article>
  </main>
  <Footer />
</Base>

<style>
.feature-page {
  padding: 48px 0 0;
}
.feature-hero {
  max-width: 720px;
  margin: 0 auto 48px;
}
.feature-back {
  display: inline-block;
  font-size: 0.84rem;
  color: var(--primary);
  text-decoration: none;
  font-weight: 500;
  margin-bottom: 24px;
}
.feature-back:hover { text-decoration: underline; }
.feature-hero h1 {
  font-size: clamp(2rem, 4vw, 2.8rem);
  color: var(--ink);
  line-height: 1.2;
  margin-bottom: 16px;
}
.feature-sub {
  font-size: 1.1rem;
  color: var(--ink-muted);
  line-height: 1.65;
  max-width: 600px;
}
.feature-bullets {
  max-width: 720px;
  margin: 0 auto 48px;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
.feature-bullet {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 0.925rem;
  color: var(--ink);
}
.feature-bullet .proof-check {
  margin-top: 3px;
  flex-shrink: 0;
}
.feature-body {
  max-width: 720px;
  margin: 0 auto;
  font-size: 1.05rem;
  line-height: 1.78;
  color: var(--ink-muted);
}
.feature-body :global(h2) {
  font-size: 1.5rem;
  color: var(--ink);
  margin-top: 40px;
  margin-bottom: 16px;
  font-family: var(--font-serif);
}
.feature-body :global(h3) {
  font-size: 1.2rem;
  color: var(--ink);
  margin-top: 32px;
  margin-bottom: 12px;
  font-family: var(--font-sans);
  font-weight: 600;
}
.feature-body :global(p) { margin-bottom: 20px; }
.feature-body :global(ul),
.feature-body :global(ol) { padding-left: 24px; margin-bottom: 20px; }
.feature-body :global(li) { margin-bottom: 8px; }
.feature-body :global(blockquote) {
  border-left: 3px solid var(--primary);
  padding-left: 20px;
  margin: 24px 0;
  font-style: italic;
  color: var(--ink);
}
.feature-body :global(a) { color: var(--primary); text-decoration: none; font-weight: 500; }
.feature-body :global(a:hover) { text-decoration: underline; }
.feature-body :global(strong) { color: var(--ink); font-weight: 600; }
.feature-faq {
  max-width: 720px;
  margin: 56px auto 0;
  border-top: 1px solid var(--border);
  padding-top: 40px;
}
.feature-faq h2 {
  font-size: 1.4rem;
  color: var(--ink);
  margin-bottom: 28px;
  font-family: var(--font-sans);
}
.feature-faq-item {
  margin-bottom: 24px;
}
.feature-faq-item h3 {
  font-size: 1rem;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 6px;
  font-family: var(--font-sans);
}
.feature-faq-item p {
  font-size: 0.925rem;
  color: var(--ink-muted);
  line-height: 1.68;
}
@media (max-width: 640px) {
  .feature-bullets { grid-template-columns: 1fr; }
}
</style>
