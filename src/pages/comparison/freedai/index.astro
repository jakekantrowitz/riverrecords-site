<script is:inline>
// Override nav CTA for this page
const navCta = document.querySelector('.nav-cta');
if (navCta) {
  navCta.href = 'https://stream.riverrecords.ai/onboard/stream-pro?utm_source=compare-freed&utm_medium=landing&utm_campaign=conquest-v4&utm_content=sticky-nav';
  const full = navCta.querySelector('.nav-cta-full');
  const short = navCta.querySelector('.nav-cta-short');
  if (full) full.textContent = 'Start free for 30 days →';
  if (short) short.textContent = 'Start free →';
}

// Scroll reveal
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('visible'); obs.unobserve(e.target); }});
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.freed-reveal').forEach(el => obs.observe(el));
</script>

