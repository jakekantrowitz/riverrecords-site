---
import Page from '../layouts/Page.astro';
import HeroSection from '../components/HeroSection.astro';
import ProofStrip from '../components/ProofStrip.astro';
import StepMock from '../components/StepMock.astro';
import FeatureCell from '../components/FeatureCell.astro';
import PhilBlock from '../components/PhilBlock.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CtaDark from '../components/CtaDark.astro';
---
<Page
  title="Stream — AI Medical Scribe with Memory | Problem-Based Notes"
  description="Stream is your AI scribe and clinical assistant — organized by medical problem, not by date. Faster notes today. A smarter chart tomorrow. 30-day free trial.">

<style>
/* ── PAGE-SPECIFIC STYLES ───────────────────────────── */

/* Research stat block */
.stat-block {
  padding: 72px 0;
  background: var(--dark);
  color: var(--white);
}
.stat-block-inner {
  max-width: 720px;
  margin: 0 auto;
  text-align: center;
}
.stat-block h2 {
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  color: var(--white);
  line-height: 1.25;
  margin-bottom: 24px;
}
.stat-pullquote {
  font-size: 1.05rem;
  color: rgba(255,255,255,0.7);
  line-height: 1.72;
  margin-bottom: 16px;
  font-style: italic;
}
.stat-pullquote em {
  font-style: normal;
  color: rgba(255,255,255,0.9);
}
.stat-citation {
  font-size: 0.82rem;
  color: rgba(255,255,255,0.4);
  margin-bottom: 28px;
}
.stat-citation a {
  color: rgba(255,255,255,0.4);
  text-decoration: none;
  border-bottom: 1px solid rgba(255,255,255,0.2);
  transition: color 0.12s, border-color 0.12s;
}
.stat-citation a:hover {
  color: var(--accent-light);
  border-color: var(--accent-light);
}
.stat-citation em {
  font-style: italic;
}
.stat-closer {
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--white);
  letter-spacing: -0.01em;
}

/* Hero — index-specific additions */
.hero::after {
  content: '';
  position: absolute; inset: 0;
  background-image: radial-gradient(circle, rgba(36,89,158,0.13) 1px, transparent 1px);
  background-size: 32px 32px;
  mask-image: radial-gradient(ellipse 55% 50% at 50% 50%, black 0%, transparent 80%);
  -webkit-mask-image: radial-gradient(ellipse 55% 50% at 50% 50%, black 0%, transparent 80%);
  pointer-events: none;
  opacity: 0.5;
}
.hero h1 { font-size: clamp(2.6rem, 5.5vw, 4rem); }

/* Real widget container */
.hero-ui {
  margin-top: 60px;
  position: relative; z-index: 1;
  animation: fadeUp 0.8s 0.5s ease both;
}
.hero-widgets-wrap {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--r-xl);
  box-shadow: var(--shadow-lg);
  overflow: hidden;
  max-width: 900px;
  margin: 0 auto;
}
.hw-chrome {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 10px 18px;
  display: flex; align-items: center; gap: 12px;
}
.hw-chrome-label {
  font-size: 0.7rem; font-weight: 500;
  color: var(--ink-faint); flex: 1; text-align: center; letter-spacing: 0.02em;
}
.ui-dots { display: flex; gap: 6px; }
.ui-dot  { width: 11px; height: 11px; border-radius: 50%; }
.ui-dot-r { background: #ff6057; }
.ui-dot-y { background: #ffbd2e; }
.ui-dot-g { background: #28c940; }
.hw-body {
  display: grid;
  grid-template-columns: 260px 1fr;
  min-height: 380px;
  align-items: stretch;
}
.hw-col-left  { border-right: 1px solid var(--border); padding: 16px 16px 0 16px; }
.hw-col-right { padding: 16px; }

/* How It Works */
.how { padding: 88px 0 72px; }
.how-header { max-width: 700px; margin-bottom: 56px; }
.how-header h2 {
  font-size: clamp(2rem, 3.8vw, 2.8rem);
  color: var(--ink);
  margin-bottom: 14px;
}
.how-header h2 em { font-style: italic; color: var(--primary); }
.how-header p { font-size: 1rem; color: var(--ink-muted); line-height: 1.65; }

.how-steps { display: flex; flex-direction: column; }
.how-step {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 56px;
  align-items: center;
  padding: 60px 0;
  border-top: 1px solid var(--border);
}
.how-step:last-child { border-bottom: 1px solid var(--border); }
.how-step.reverse .how-step-visual { order: -1; }
.how-step-num {
  font-family: var(--font-serif);
  font-size: 0.82rem;
  color: var(--primary);
  margin-bottom: 12px;
  letter-spacing: 0.02em;
}
.how-step h3 {
  font-size: clamp(1.45rem, 2.4vw, 1.85rem);
  color: var(--ink);
  margin-bottom: 12px;
}
.how-step p { font-size: 0.975rem; color: var(--ink-muted); line-height: 1.68; margin-bottom: 16px; }
.how-step-aside {
  font-size: 0.82rem;
  color: var(--ink-faint);
  font-style: italic;
  padding-left: 14px;
  border-left: 2px solid var(--border-strong);
  line-height: 1.55;
}

/* Waveform */
.waveform {
  display: flex; align-items: center; gap: 3px; height: 44px; margin-bottom: 14px;
}
.waveform-bar {
  width: 4px; border-radius: 2px;
  background: var(--accent); opacity: 0.65;
  animation: wave 1.2s ease-in-out infinite;
}
@keyframes wave {
  0%,100% { transform: scaleY(1); }
  50%      { transform: scaleY(0.35); }
}
.waveform-bar:nth-child(1)  { height:20%; animation-delay:0s }
.waveform-bar:nth-child(2)  { height:55%; animation-delay:.1s }
.waveform-bar:nth-child(3)  { height:82%; animation-delay:.2s }
.waveform-bar:nth-child(4)  { height:38%; animation-delay:.3s }
.waveform-bar:nth-child(5)  { height:95%; animation-delay:.15s }
.waveform-bar:nth-child(6)  { height:62%; animation-delay:.25s }
.waveform-bar:nth-child(7)  { height:28%; animation-delay:.35s }
.waveform-bar:nth-child(8)  { height:78%; animation-delay:.05s }
.waveform-bar:nth-child(9)  { height:48%; animation-delay:.4s }
.waveform-bar:nth-child(10) { height:68%; animation-delay:.2s }
.waveform-bar:nth-child(11) { height:32%; animation-delay:.3s }
.waveform-bar:nth-child(12) { height:58%; animation-delay:.1s }
.waveform-bar:nth-child(13) { height:42%; animation-delay:.45s }
.waveform-bar:nth-child(14) { height:72%; animation-delay:.15s }
.waveform-bar:nth-child(15) { height:24%; animation-delay:.35s }
.waveform-bar:nth-child(16) { height:53%; animation-delay:0s }

.transcript-lines { display: flex; flex-direction: column; gap: 6px; }
.tl { height: 8px; border-radius: 4px; background: var(--surface-mid); }
.tl.accent { background: rgba(36,89,158,0.2); }
.tl.w-full { width:100% }
.tl.w-4-5  { width:80%  }
.tl.w-3-5  { width:62%  }
.tl.w-2-5  { width:46%  }
.transcript-label {
  font-size: 0.67rem;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--ink-faint);
  margin-bottom: 10px;
}
.generating {
  margin-top: 14px;
  font-size: 0.76rem;
  color: var(--primary);
  font-weight: 600;
}

/* Problem list mock */
.prob-list { display: flex; flex-direction: column; gap: 7px; }
.prob-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 9px 11px;
  border-radius: var(--r-sm);
  border: 1px solid var(--border);
  background: var(--surface);
}
.prob-row.active-row { background: var(--primary-light); border-color: var(--primary-border); }
.prob-row-left { display: flex; align-items: center; gap: 9px; }
.prob-icon {
  width: 26px; height: 26px;
  border-radius: 6px;
  background: var(--surface-mid);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.72rem;
}
.active-row .prob-icon { background: rgba(36,89,158,0.15); }
.prob-name  { font-size: 0.8rem; font-weight: 600; color: var(--ink); }
.prob-visits{ font-size: 0.67rem; color: var(--ink-faint); }
.prob-pill  {
  font-size: 0.62rem; font-weight: 700;
  padding: 3px 7px; border-radius: var(--r-pill);
  letter-spacing: 0.04em; text-transform: uppercase;
}
.pill-active   { background: var(--primary-light); color: var(--primary); }
.pill-stable   { background: var(--surface-mid); color: var(--ink-faint); }
.pill-monitor  { background: #fef9ec; color: var(--gold); }

/* Task mock */
.task-list { display: flex; flex-direction: column; gap: 7px; }
.task-item {
  display: flex; align-items: flex-start; gap: 9px;
  padding: 9px 11px;
  border-radius: var(--r-sm);
  border: 1px solid var(--border);
  background: var(--surface);
}
.task-cb {
  width: 17px; height: 17px;
  border-radius: 4px;
  border: 1.5px solid var(--border-strong);
  flex-shrink: 0; margin-top: 1px;
}
.task-cb.checked {
  background: var(--primary); border-color: var(--primary);
  display: flex; align-items: center; justify-content: center;
}
.task-cb.checked::after {
  content: '';
  width: 8px; height: 5px;
  border-left: 1.5px solid #fff;
  border-bottom: 1.5px solid #fff;
  transform: rotate(-45deg) translate(1px,-1px);
}
.task-text { font-size: 0.78rem; color: var(--ink-muted); line-height: 1.42; }
.task-text strong { color: var(--ink); font-weight: 600; font-size: 0.8rem; }
.task-tag {
  margin-left: auto;
  font-size: 0.62rem; font-weight: 600;
  padding: 2px 7px; border-radius: 4px;
  white-space: nowrap; align-self: flex-start;
}
.tag-urgent  { background: #fef2f2; color: var(--freed-red); border: 1px solid rgba(201,64,64,0.2); }
.tag-routine { background: var(--primary-light); color: var(--primary); border: 1px solid var(--primary-border); }

/* Features grid — styles in shared.css */
/* Testimonials */
.testimonials { padding: 80px 0 72px; }
.testimonials-header { margin-bottom: 40px; }
.testimonials-header h2 {
  font-size: clamp(1.9rem, 3.5vw, 2.6rem);
  color: var(--ink);
  margin-bottom: 8px;
}
.testimonials-header p { font-size: 1rem; color: var(--ink-muted); }
.tgrid { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; margin-bottom: 14px; }
.tgrid-2 { display: grid; grid-template-columns: repeat(2,1fr); gap: 14px; max-width: 700px; }
.tgrid-all {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 14px;
}
.tgrid-all :global(.tcard:nth-child(1)) { grid-column: 1 / 3; }
.tgrid-all :global(.tcard:nth-child(2)) { grid-column: 3 / 5; }
.tgrid-all :global(.tcard:nth-child(3)) { grid-column: 5 / 7; }
.tgrid-all :global(.tcard:nth-child(4)) { grid-column: 1 / 4; }
.tgrid-all :global(.tcard:nth-child(5)) { grid-column: 4 / 7; }

/* Pricing */
.pricing {
  padding: 80px 0 72px;
  background: var(--white);
  border-top: 1px solid var(--border);
}
.pricing-header { text-align: center; margin-bottom: 44px; }
.pricing-header h2 {
  font-size: clamp(2rem, 3.8vw, 2.8rem);
  color: var(--ink);
  margin-bottom: 8px;
}
.pricing-header p { font-size: 1rem; color: var(--ink-muted); margin-bottom: 20px; }

.pricing-toggle {
  display: inline-flex;
  background: var(--surface-mid);
  border-radius: var(--r-pill);
  padding: 4px; gap: 2px;
}
.toggle-btn {
  font-size: 0.8rem; font-weight: 600;
  padding: 7px 18px; border-radius: var(--r-pill);
  cursor: pointer; transition: background 0.15s, color 0.15s;
  color: var(--ink-faint); border: none; background: none;
  font-family: var(--font-sans);
}
.toggle-btn.active { background: var(--white); color: var(--ink); box-shadow: var(--shadow-xs); }

.pricing-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18px;
  max-width: 840px;
  margin: 0 auto;
  align-items: stretch;
}
.pcard {
  background: var(--white);
  border: 1.5px solid var(--border-strong);
  border-radius: var(--r-xl);
  padding: 38px;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-sm);
}
.pcard-featured {
  background: var(--white);
  border: 1.5px solid rgba(36,89,158,0.4);
  box-shadow: var(--shadow-md);
}
.pcard-featured::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--primary), var(--primary-dark));
}
.pcard-offer {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #fef9ec;
  color: var(--gold);
  border: 1px solid rgba(201,149,74,0.3);
  border-radius: var(--r-pill);
  padding: 4px 12px;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.04em;
}
.pcard-badge {
  display: inline-block;
  background: var(--primary);
  color: var(--white);
  font-size: 0.67rem;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  padding: 3px 10px;
  border-radius: 4px;
}
.pcard-name { font-size: 0.76rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-faint); margin-bottom: 6px; }
.pcard-desc { font-size: 0.86rem; color: var(--ink-muted); margin-bottom: 24px; line-height: 1.5; }
.pcard-amount {
  font-family: var(--font-serif);
  font-size: 3rem;
  letter-spacing: -0.04em;
  color: var(--ink);
  line-height: 1;
}
.pcard-amount-sub { font-size: 1rem; color: var(--ink-muted); vertical-align: super; font-family: var(--font-sans); font-weight: 400; }
.pcard-period { font-size: 0.8rem; color: var(--ink-faint); margin-top: 4px; margin-bottom: 6px; }
.pcard-normal { font-size: 0.78rem; color: var(--ink-faint); margin-bottom: 24px; }
.pcard-normal s { color: var(--freed-red); }
.pcard-divider { height: 1px; background: var(--border); margin-bottom: 22px; }
.pcard-features { list-style: none; display: flex; flex-direction: column; gap: 9px; margin-bottom: 28px; flex-grow: 1; }
.pcard-features li {
  font-size: 0.865rem;
  color: var(--ink-muted);
  display: flex; align-items: flex-start; gap: 9px;
}
.pf-check {
  flex-shrink: 0;
  width: 17px; height: 17px;
  border-radius: 50%;
  background: var(--primary-light);
  border: 1px solid var(--primary-border);
  display: flex; align-items: center; justify-content: center;
  margin-top: 1px;
}
.pf-check::after {
  content: '';
  width: 7px; height: 5px;
  border-left: 1.5px solid var(--primary);
  border-bottom: 1.5px solid var(--primary);
  transform: rotate(-45deg) translate(1px,-1px);
  margin-top: 1px;
}
.pcard .btn-primary-lg { width: 100%; max-width: 360px; display: block; margin: 0 auto; text-align: center; justify-content: center; }
.pcard .btn-outline { width: 100%; max-width: 360px; display: block; margin: 0 auto; text-align: center; justify-content: center; border: 1.5px solid var(--border-strong); color: var(--ink); font-weight: 600; background: var(--white); }
.pcard .btn-outline:hover { border-color: var(--primary); color: var(--primary); }
.pcard-footnote { font-size: 0.73rem; color: var(--ink-faint); text-align: center; margin-top: 10px; }

/* FAQ */
.faq { padding: 80px 0 72px; }
.faq-header { max-width: 540px; margin-bottom: 40px; }
.faq-header h2 { font-size: clamp(1.6rem, 2.8vw, 2.2rem); color: var(--ink); margin-bottom: 8px; }
.faq-header p  { font-size: 1rem; color: var(--ink-muted); }
.faq-grid { display: grid; grid-template-columns: 1fr; gap: 10px; max-width: 760px; }
.faq-item {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  overflow: hidden;
  box-shadow: var(--shadow-xs);
}
.faq-item.open {
  border-left: 3px solid var(--primary);
}
.faq-q {
  width: 100%; text-align: left;
  padding: 18px 22px;
  font-size: 0.915rem; font-weight: 600; color: var(--ink);
  background: none; border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: space-between; gap: 14px;
  font-family: var(--font-sans); line-height: 1.4;
}
.faq-q:hover { background: var(--surface); }
.faq-icon {
  width: 21px; height: 21px; border-radius: 50%;
  background: var(--surface-mid);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; font-size: 1rem; color: var(--ink-muted);
  transition: background 0.15s, transform 0.2s;
}
.faq-item.open .faq-icon { background: var(--primary-light); color: var(--primary); }
.faq-a {
  display: none; padding: 0 22px 18px;
  font-size: 0.875rem; color: var(--ink-muted); line-height: 1.68;
  border-top: 1px solid var(--border); padding-top: 14px;
}
.faq-item.open .faq-a { display: block; }

/* Final CTA & sections */
.final-cta { padding: 80px 0 88px; }
.philosophy-section { padding: 72px 0; }

/* Responsive */
@media (max-width: 900px) {
  .hw-body { grid-template-columns: 1fr; }
  .hw-col-left { border-right: none; border-bottom: 1px solid var(--border); }
  .ui-body { grid-template-columns: 1fr; }
  .ui-sidebar { display: none; }
  .how-step { grid-template-columns: 1fr; gap: 28px; }
  .how-step.reverse .how-step-visual { order: 0; }
  .tgrid { grid-template-columns: repeat(2,1fr); }
  .tgrid-2 { grid-template-columns: 1fr; max-width: 420px; }
  .tgrid-all { grid-template-columns: repeat(2, 1fr); }
  .tgrid-all :global(.tcard:nth-child(1)),
  .tgrid-all :global(.tcard:nth-child(2)),
  .tgrid-all :global(.tcard:nth-child(3)),
  .tgrid-all :global(.tcard:nth-child(4)),
  .tgrid-all :global(.tcard:nth-child(5)) { grid-column: span 1; }
  .tgrid-all :global(.tcard:nth-child(5)) { grid-column: 1 / -1; max-width: 50%; }
  .pricing-cards { grid-template-columns: 1fr; max-width: 460px; }
}
@media (max-width: 640px) {
  .tgrid { grid-template-columns: 1fr; }
  .tgrid-all { grid-template-columns: 1fr; }
  .tgrid-all :global(.tcard:nth-child(5)) { max-width: 100%; }
  .hero h1 { font-size: 2.2rem; }
  .hero-actions { flex-direction: column; width: 100%; }
  .hero-actions .btn-primary-lg,
  .hero-actions .btn-outline { width: 100%; justify-content: center; }
}
</style>

<Fragment slot="head">
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Stream by River Records",
    "applicationCategory": "HealthApplication",
    "operatingSystem": "Web",
    "description": "AI medical scribe with memory. Problem-based clinical notes for primary care, SNF, and long-term care.",
    "offers": {
      "@type": "Offer",
      "price": "149",
      "priceCurrency": "USD"
    }
  }
  </script>
</Fragment>

<!-- HERO -->
<HeroSection
  eyebrow='AI built by clinicians, for clinicians · <a href="/about#research" style="color:inherit;text-decoration:underline;text-underline-offset:2px;">5 peer-reviewed publications</a>'
  sub="Stream is your AI scribe and clinical assistant — organized by medical problem, not by date. Faster notes today. A smarter chart tomorrow."
  secondaryHref="/book-demo"
  secondaryLabel="Talk to a clinician first"
  trustItems={["No credit card required", "30-day free trial", "$149/month after trial", "HIPAA Compliant", "Founded by practicing physicians"]}
  animatedDot
>
  Reimagine<br><em>Medical Documentation.</em>
  <div class="hero-ui" slot="below">
    <div class="hero-widgets-wrap">
      <div class="hw-chrome">
        <div class="ui-dots">
          <div class="ui-dot ui-dot-r"></div>
          <div class="ui-dot ui-dot-y"></div>
          <div class="ui-dot ui-dot-g"></div>
        </div>
        <div class="hw-chrome-label">Stream — Margaret T., 58F · Problem-Oriented Chart</div>
      </div>
      <div class="hw-body">
        <div class="hw-col-left" id="hero-problem-list"></div>
        <div class="hw-col-right" id="hero-note-card"></div>
      </div>
    </div>
  </div>
</HeroSection>

<!-- PROOF STRIP -->
<ProofStrip items={["Trusted by internists, pediatricians, and SNF clinicians", "Works alongside any EHR", "30-day free trial", "HIPAA Compliant", "Built by primary care physicians"]} />

<!-- RESEARCH STAT BLOCK -->
<section class="stat-block reveal">
  <div class="container">
    <div class="stat-block-inner">
      <h2>Half of everything in your patient's chart is copy-pasted noise.</h2>
      <p class="stat-pullquote">The average patient chart contains roughly half the words of <em>Hamlet</em> — and research shows half of that text is duplicated word-for-word from prior notes. That fraction grows every year.</p>
      <p class="stat-citation"><a href="https://jamanetwork.com/journals/jamanetworkopen/fullarticle/2796664" target="_blank" rel="noopener">Steinkamp, Kantrowitz et al. — <em>JAMA Network Open</em>, 2022</a></p>
      <p class="stat-closer">We didn't build a better scribe. We rebuilt the paradigm.</p>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="how" id="how-it-works">
  <div class="container">
    <div class="how-header reveal">
      <span class="section-label">How it works</span>
      <h2>Every feature designed to save <em>minutes now and hours later.</em></h2>
      <p>Stream combines a real-time AI scribe with a problem-oriented chart that builds longitudinal context across every encounter.</p>
    </div>
    <div class="how-steps">

      <div class="how-step reveal">
