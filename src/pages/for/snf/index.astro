---
import Page from '../../../layouts/Page.astro';
import HeroSection from '../../../components/HeroSection.astro';
import ProofStrip from '../../../components/ProofStrip.astro';
import PainCard from '../../../components/PainCard.astro';
import PhilBlock from '../../../components/PhilBlock.astro';
import StepMock from '../../../components/StepMock.astro';
import FeatureCell from '../../../components/FeatureCell.astro';
import TestimonialCard from '../../../components/TestimonialCard.astro';
import CtaDark from '../../../components/CtaDark.astro';
---
<Page
  title="AI Scribe for SNF & Long-Term Care — Stream"
  description="Stream is the AI medical scribe built for skilled nursing and long-term care. Import discharge summaries, build a problem-oriented chart from day one, and never lose track of a follow-up. 30-day free trial.">

<style>
/* Pain section */
.pain { padding: 72px 0 60px; }
.pain h2 {
  font-size: clamp(1.9rem, 3.5vw, 2.7rem);
  color: var(--ink);
  margin-bottom: 14px;
}
.pain-lead { font-size: 1rem; color: var(--ink-muted); max-width: 580px; line-height: 1.65; margin-bottom: 36px; }
.pain-cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; }

/* How it works */
.how { padding: 88px 0 72px; }
.how-header { max-width: 700px; margin-bottom: 56px; }
.how-header h2 {
  font-size: clamp(2rem, 3.8vw, 2.8rem);
  color: var(--ink);
  margin-bottom: 8px;
}
.how-header p { font-size: 1rem; color: var(--ink-muted); line-height: 1.65; }
.how-steps { display: flex; flex-direction: column; }
.how-step {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 56px;
  align-items: center;
  padding: 60px 0;
  border-top: 1px solid var(--border);
}
.how-step:last-child { border-bottom: 1px solid var(--border); }
.how-step.reverse .how-step-visual { order: -1; }
.how-step-num {
  font-family: var(--font-serif);
  font-size: 0.82rem;
  color: var(--primary);
  margin-bottom: 12px;
  letter-spacing: 0.02em;
}
.how-step h3 {
  font-size: clamp(1.45rem, 2.4vw, 1.85rem);
  color: var(--ink);
  margin-bottom: 12px;
}
.how-step p { font-size: 0.975rem; color: var(--ink-muted); line-height: 1.68; margin-bottom: 16px; }
.how-step-aside {
  font-size: 0.82rem;
  color: var(--ink-faint);
  font-style: italic;
  padding-left: 14px;
  border-left: 2px solid var(--border-strong);
  line-height: 1.55;
}

/* Features grid — styles in shared.css */

/* Testimonials */
.testimonials { padding: 64px 0 52px; }
.testimonials-header { margin-bottom: 40px; }
.testimonials-header h2 {
  font-size: clamp(1.9rem, 3.5vw, 2.6rem);
  color: var(--ink);
  margin-bottom: 8px;
}
.testimonials-header p { font-size: 1rem; color: var(--ink-muted); }
.tgrid { display: grid; grid-template-columns: repeat(2,1fr); gap: 14px; max-width: 700px; }

/* Pricing callout */
.pricing-callout { padding: 64px 0; }
.pricing-card {
  background: var(--white);
  border: 1.5px solid rgba(36,89,158,0.4);
  border-radius: var(--r-xl);
  padding: 40px;
  max-width: 480px;
  margin: 0 auto;
  box-shadow: var(--shadow-md);
  text-align: center;
  position: relative;
  overflow: hidden;
}
.pricing-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--primary), var(--primary-dark));
}
.pricing-card h2 { font-size: 2rem; color: var(--ink); margin-bottom: 10px; }
.pricing-card p { font-size: 1rem; color: var(--ink-muted); line-height: 1.6; margin-bottom: 24px; }
.pricing-card .btn-primary-lg { max-width: 360px; width: 100%; display: block; margin: 0 auto; text-align: center; }
.pricing-small { font-size: 0.78rem; color: var(--ink-faint); margin-top: 12px; }

/* Final CTA */
.final-cta { padding: 72px 0 88px; }

/* Responsive */
@media (max-width: 900px) {
  .pain-cards { grid-template-columns: 1fr; }
  .how-step { grid-template-columns: 1fr; gap: 28px; }
  .how-step.reverse .how-step-visual { order: 0; }
  .tgrid { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
}
</style>

<!-- HERO -->
<HeroSection
  eyebrow="Built for SNF · LTC · Post-Acute Care"
  sub="Upload the discharge summary, Stream builds a problem-oriented chart in minutes. From day one, you know exactly where this patient stands — and where to take them next."
  primaryHref="/book-demo"
  primaryLabel="Talk to a clinician first"
  secondaryHref="https://stream.riverrecords.ai/onboard/stream-pro"
  secondaryLabel="Start Free Trial"
  trustItems={["No credit card required", "30-day free trial", "$149/month after trial", "HIPAA Compliant"]}
>
  Your new admission just arrived<br>with a 40-page discharge summary.<br><em>Stream reads it so you don't have to.</em>
</HeroSection>

<!-- PROOF STRIP -->
<ProofStrip items={["Built by physicians", "Works alongside any EHR", "30-day free trial", "HIPAA Compliant"]} />

<!-- PAIN -->
<section class="pain">
  <div class="container">
    <span class="section-label reveal">The SNF documentation burden</span>
    <h2 class="reveal">Every admission is a chart<br>you have to rebuild from scratch.</h2>
    <p class="pain-lead reveal">Skilled nursing and long-term care carries some of the most complex documentation in medicine. High-acuity admissions, detailed outside records, and patients whose histories span years — all landing on your desk at once. Stream is built for exactly this.</p>
    <div class="pain-cards reveal">
      <PainCard icon="📄" title="The admission stack" body="A new patient arrives from the hospital with a discharge summary, consult notes, labs, and imaging reports. Reading and summarizing all of it before you can even begin to plan care takes hours you don't have." />
      <PainCard icon="🔄" title="Complex patients, fragmented records" body="Your patients have long histories across multiple systems. Piecing together what happened before they arrived — and making sure nothing important gets missed — is a clinical risk, not just an inconvenience." />
      <PainCard icon="✅" title="Follow-ups that fall through the cracks" body="Pending labs, wound care updates, specialist referrals, medication reconciliation. In a busy SNF, open loops don't just create paperwork — they create patient safety risk." />
    </div>
  </div>
</section>

<!-- PHILOSOPHY -->
<section style="padding: 56px 0;">
  <div class="container">
    <PhilBlock label="Why post-acute care needs something different" name="Jake Kantrowitz, MD" title="Primary Care Physician · Co-Founder, River Records">
      "Every SNF admission is a longitudinal project that started somewhere else. The discharge summary is chapter one. Stream is the tool that turns that stack of outside records into a chart you can actually use — from day one."
    </PhilBlock>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="how">
  <div class="container">
    <div class="how-header reveal">
      <span class="section-label">How it works</span>
      <h2>From discharge summary to organized chart in minutes.</h2>
      <p>Not hours. Not days. Minutes.</p>
    </div>
    <div class="how-steps">

      <div class="how-step reveal">
        <div class="how-step-copy">
          <div class="how-step-num">Step 01 — Seed the chart</div>
          <h3>Upload the discharge summary. Stream does the rest.</h3>
          <p>When a new patient arrives, upload their discharge summary or any outside records directly into Stream. Within a couple of minutes, Stream extracts the key problems, medications, and clinical history — and organizes everything into a problem-oriented chart ready for your first encounter. No manual summarizing. No starting from scratch.</p>
          <p class="how-step-aside">Works with discharge summaries, consult notes, labs, and PDF records. Upload once — Stream handles the rest.</p>
        </div>
        <div class="how-step-visual">
          <StepMock header="Problem Summary" flush>
            <div id="snf-problem-summary"></div>
          </StepMock>
        </div>
      </div>

      <div class="how-step reverse reveal">
        <div class="how-step-copy">
          <div class="how-step-num">Step 02 — Round and document</div>
          <h3>Speak naturally during rounds. Notes are done before you leave the room.</h3>
          <p>Record your encounter or dictate as you go. Stream transcribes in real time, structures the note by problem, and updates the chart automatically. Each visit builds on the last — so the chart gets smarter with every encounter, not just longer.</p>
          <p class="how-step-aside">Supports 22 languages. Works ambient or with direct dictation. Customizable templates for SNF and LTC documentation requirements.</p>
        </div>
        <div class="how-step-visual">
          <StepMock header="Recording in progress">
            <div id="snf-waveform"></div>
          </StepMock>
        </div>
      </div>

      <div class="how-step reveal">
        <div class="how-step-copy">
          <div class="how-step-num">Step 03 — Track every open loop</div>
          <h3>Nothing falls through the cracks between visits.</h3>
          <p>Follow-up tasks are generated automatically from every note — labs to recheck, referrals to track, medication changes to reconcile. Every open loop is captured and visible, so you're never relying on memory or a paper list to manage your panel.</p>
          <p class="how-step-aside">Coming soon: referral loop tracking and inter-facility communication — so you always know what happened after the handoff.</p>
        </div>
        <div class="how-step-visual">
          <StepMock header="Auto-Generated Tasks" flush>
            <div id="snf-task-list"></div>
          </StepMock>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- FEATURES -->
<section class="features">
  <div class="container">
    <div class="features-header reveal">
      <span class="section-label">Built for your workflow</span>
      <h2>Every feature built for high-complexity, longitudinal care.</h2>
    </div>
    <div class="features-grid reveal">
      <FeatureCell icon="📁" title="Discharge Summary Import" body="Upload outside records and Stream extracts the problems, medications, and history — building a structured chart from day one of admission." />
      <FeatureCell icon="🗂️" title="Problem-Oriented Chart" body="Every encounter updates a living chart organized by medical problem. Complex patients with long histories stay organized, not buried." />
      <FeatureCell icon="🎙️" title="Real-Time AI Scribe" body="Ambient recording or direct dictation during rounds. Stream writes a complete, structured note while you focus on your patient." />
      <FeatureCell icon="✅" title="Automatic Task Tracking" body="Follow-up tasks extracted from every note automatically. Nothing gets lost between visits or across your panel." />
      <FeatureCell icon="💻" title="ICD & CPT Coding" body="Diagnosis and procedure codes suggested at the point of care. Accurate coding without slowing down your rounds." />
      <FeatureCell icon="📋" title="Patient & Problem Summaries" body="One-tap summaries for any problem or patient — perfect for handoffs, family conversations, and care plan meetings." />
    </div>
  </div>
</section>

<!-- TESTIMONIALS -->
<section class="testimonials">
  <div class="container">
    <div class="testimonials-header reveal">
      <span class="section-label">What clinicians say</span>
      <h2>Built by physicians. Trusted by clinicians.</h2>
      <p>Feedback from clinicians managing complex, longitudinal patients.</p>
    </div>
    <div class="tgrid reveal">
      <TestimonialCard initials="KV" name="Karen Valentine, NP" title="Long-Term Care" quote="I was using another AI scribe, but now I love Stream!" />
      <TestimonialCard initials="DK" name="Donna Kirchoff, MD, FAAP" title="Integrative Developmental & Behavioral Pediatrics" quote="I can review and reuse information from previous visits inside Stream — creating a more comprehensive note every time." />
    </div>
  </div>
</section>

<!-- PRICING CALLOUT -->
<section class="pricing-callout">
  <div class="container">
    <div class="pricing-card reveal">
      <h2>$149/month. Start free.</h2>
      <p>Unlimited visits. Works alongside any EHR. 30-day free trial, no credit card required.</p>
      <a href="https://stream.riverrecords.ai/onboard/stream-pro" class="btn btn-primary-lg">Start Free Trial →</a>
      <div class="pricing-small">Cancel anytime. Annual billing available at $99/month.</div>
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="final-cta">
  <div class="container">
    <CtaDark primaryHref="/book-demo" primaryLabel="Talk to a clinician first" secondaryHref="https://stream.riverrecords.ai/onboard/stream-pro" secondaryLabel="Start Free Trial">
      From admission to organized chart in minutes.<br><em>See it live on a 20-minute demo.</em>
      <Fragment slot="body">We'll walk you through the discharge summary workflow and show you exactly how Stream works in a SNF setting. No pitch — just the product.</Fragment>
    </CtaDark>
  </div>
</section>

<script is:inline>
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('visible'); obs.unobserve(e.target); }});
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

document.addEventListener('DOMContentLoaded', function() {
  StreamWidgets.ProblemSummaryCard('#snf-problem-summary');
  StreamWidgets.WaveformWidget('#snf-waveform', { autoStart: true });
  StreamWidgets.TaskListWidget('#snf-task-list');
});
</script>

</Page>
