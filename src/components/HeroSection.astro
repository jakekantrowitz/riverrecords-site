---
const {
  eyebrow,
  sub,
  primaryHref = 'https://stream.riverrecords.ai/onboard/stream-pro',
  primaryLabel = 'Try it on your next visit',
  secondaryHref,
  secondaryLabel,
  trustItems = [],
  animatedDot = false,
} = Astro.props;
---
<section class="hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-eyebrow">
        {animatedDot ? <span class="hero-eyebrow-dot"></span> : null}
        <Fragment set:html={eyebrow} />
      </div>
      <h1><slot /></h1>
      <p class="hero-sub">{sub}</p>
      <div class="hero-actions">
        <a href={primaryHref} class="btn btn-primary-lg">{primaryLabel}</a>
        {secondaryHref && <a href={secondaryHref} class="btn btn-outline">{secondaryLabel}</a>}
      </div>
      {trustItems.length > 0 && (
        <div class="hero-trust">
          {trustItems.map((item: string, i: number) => (
            <>
              {i > 0 && <div class="hero-trust-dot"></div>}
              <span>{item}</span>
            </>
          ))}
        </div>
      )}
      <slot name="below" />
    </div>
  </div>
</section>

<style>
.hero {
  padding: 80px 0 68px;
  position: relative;
  overflow: hidden;
  text-align: center;
}
.hero::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 90% 70% at 50% -10%, rgba(36,89,158,0.07) 0%, transparent 65%);
  pointer-events: none;
}
.hero-content { position: relative; z-index: 1; }
.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--primary-light);
  color: var(--primary);
  border: 1px solid var(--primary-border);
  border-radius: var(--r-pill);
  padding: 5px 16px;
  font-size: 0.77rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  max-width: calc(100vw - 48px);
  flex-wrap: wrap;
  text-align: center;
  justify-content: center;
  margin-bottom: 28px;
  animation: fadeIn 0.5s ease both;
}
.hero-eyebrow-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--primary);
  animation: pulse-dot 2s ease-in-out infinite;
}
.hero h1 {
  font-size: clamp(2.4rem, 5vw, 3.6rem);
  color: var(--ink);
  max-width: 840px;
  margin: 0 auto 22px;
  animation: fadeUp 0.65s 0.1s ease both;
}
.hero h1 em, .hero h1 :global(em) { font-style: italic; color: var(--primary); }
.hero-sub {
  font-size: 1.1rem;
  color: var(--ink-muted);
  max-width: 580px;
  margin: 0 auto 36px;
  line-height: 1.68;
  animation: fadeUp 0.65s 0.2s ease both;
}
.hero-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 18px;
  animation: fadeUp 0.65s 0.3s ease both;
}
.hero-trust {
  font-size: 0.77rem;
  color: var(--ink-faint);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  flex-wrap: wrap;
  animation: fadeUp 0.5s 0.45s ease both;
}
.hero-trust-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--border-strong); }
.hero-trust span { color: var(--ink-muted); font-weight: 500; }

@media (max-width: 768px) {
  .hero { padding: 48px 0 56px; }
  .hero-eyebrow {
    padding: 4px 12px;
    font-size: 0.68rem;
    max-width: 85vw;
    margin-bottom: 20px;
    letter-spacing: 0.03em;
  }
}
@media (max-width: 640px) {
  .hero h1 { font-size: 2.2rem; }
  .hero-actions { flex-direction: column; width: 100%; }
  .hero-actions .btn-primary-lg,
  .hero-actions .btn-outline { width: 100%; justify-content: center; }
}
</style>
