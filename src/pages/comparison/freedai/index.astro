---
import Base from '../../../layouts/Base.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import HuddleDemo from '../../../components/demos/HuddleDemo.vue';
import EncounterViewDemo from '../../../components/demos/EncounterViewDemo.vue';
import TimelineRecapDemo from '../../../components/demos/TimelineRecapDemo.vue';
import { pricing } from '../../../config/pricing';

const onboardUrl = 'https://stream.riverrecords.ai/onboard/stream-pro?utm_source=compare-freed&utm_medium=landing&utm_campaign=conquest-v4';
---
<Base
  title="Stream vs. Freed — A scribe that writes your chart, not just your note | River Records"
  description="Stream is the only AI scribe that outputs Assessment & Plan per medical problem — so your chart is already organized the way you read it. 30-day free trial, no credit card.">

  <Fragment slot="head">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&family=Inter+Tight:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Stream by River Records",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "Web",
      "description": "AI medical scribe with per-problem A&P — so your chart is already organized the way you read it.",
      "offers": {
        "@type": "Offer",
        "price": "149",
        "priceCurrency": "USD",
        "description": "$149/month. Annual billing at $99/month."
      }
    }
    </script>
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "VideoObject",
      "name": "Stream vs Freed AI — Product Walkthrough",
      "description": "See how Stream's problem-oriented chart compares to Freed's visit-by-visit approach.",
      "embedUrl": "https://www.loom.com/embed/2454cf105d804ddd9632ad83539929b8",
      "uploadDate": "2026-04-01"
    }
    </script>
  </Fragment>

<style>
/* ── FREED V4 PAGE STYLES ──────────────────────────── */
/* This page uses its own design tokens and typography */

.freed-page {
  --ink: #0f1a14;
  --ink-soft: #2a3a32;
  --ink-mute: #566b60;
  --paper: #f5f1e8;
  --paper-warm: #ede6d3;
  --cream: #faf7f0;
  --stream: #1e5a3e;
  --stream-dark: #0f3a26;
  --stream-light: #e8f0ea;
  --accent: #c9563f;
  --accent-soft: #e87a61;
  --amber: #d4a44a;
  --rule: rgba(15, 26, 20, 0.12);
  --rule-strong: rgba(15, 26, 20, 0.25);

  font-family: 'Inter Tight', system-ui, sans-serif;
  color: var(--ink);
  background: var(--cream);
}

.freed-page h1, .freed-page h2, .freed-page h3 {
  font-family: 'Fraunces', Georgia, serif;
}

.freed-container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 28px;
}

/* Announcement bar */
.freed-announce {
  background: var(--stream-dark);
  color: var(--cream);
  text-align: center;
  padding: 10px 24px;
  font-size: 0.82rem;
  font-weight: 500;
}
.freed-announce strong { color: var(--accent-soft); }
.freed-announce a { color: var(--accent-soft); text-decoration: underline; text-underline-offset: 2px; margin-left: 8px; }

/* Section labels */
.freed-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-mute);
  margin-bottom: 16px;
}

/* Hero */
.freed-hero {
  padding: 72px 0 56px;
}
.freed-hero-grid {
  display: grid;
  grid-template-columns: 1.05fr 1fr;
  gap: 48px;
  align-items: center;
}
.freed-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--stream-light);
  color: var(--stream);
  border-radius: 100px;
  padding: 6px 16px;
  font-size: 0.78rem;
  font-weight: 600;
  margin-bottom: 24px;
}
.freed-eyebrow::before {
  content: '';
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--stream);
}
.freed-hero h1 {
  font-size: clamp(2.2rem, 4vw, 2.8rem);
  line-height: 1.15;
  color: var(--ink);
  margin-bottom: 18px;
  max-width: 480px;
}
.freed-hero h1 em { font-style: italic; color: var(--stream); }
.freed-hero-sub {
  font-size: 1.05rem;
  color: var(--ink-soft);
  line-height: 1.65;
  margin-bottom: 28px;
  max-width: 520px;
}
.freed-hero-sub em { font-style: italic; font-weight: 500; }
.freed-cta-row {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 18px;
}
.freed-btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--stream-dark);
  color: var(--cream);
  padding: 12px 24px;
  border-radius: 100px;
  font-size: 0.9rem;
  font-weight: 600;
  text-decoration: none;
  transition: background 0.15s;
  font-family: 'Inter Tight', system-ui, sans-serif;
}
.freed-btn-primary:hover { background: var(--stream); }
.freed-btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: none;
  color: var(--ink-soft);
  padding: 12px 24px;
  border-radius: 100px;
  border: 1.5px solid var(--rule-strong);
  font-size: 0.9rem;
  font-weight: 600;
  text-decoration: none;
  transition: border-color 0.15s, color 0.15s;
  font-family: 'Inter Tight', system-ui, sans-serif;
}
.freed-btn-secondary:hover { border-color: var(--stream); color: var(--stream); }
.freed-trust {
  font-size: 0.77rem;
  color: var(--ink-mute);
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}
.freed-trust span { display: flex; align-items: center; gap: 4px; }
.freed-trust span::before { content: '✓'; color: var(--stream); font-weight: 700; }

/* Demo frame */
.demo-frame {
  position: relative;
  background: var(--cream);
  border: 1px solid var(--rule);
  border-radius: 16px;
  padding: 8px;
  box-shadow: 0 8px 24px rgba(15, 26, 20, 0.10), 0 24px 60px rgba(15, 26, 20, 0.08);
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
}
.demo-frame__label {
  position: absolute;
  top: -12px;
  left: 20px;
  background: var(--accent);
  color: var(--cream);
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.66rem;
  letter-spacing: 0.1em;
  padding: 4px 10px;
  border-radius: 100px;
  font-weight: 600;
  z-index: 2;
}

/* Trust bar */
.freed-trustbar {
  border-top: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
  background: var(--cream);
  padding: 18px 0;
}
.freed-trustbar-inner {
  display: flex;
  align-items: center;
  gap: 8px;
  justify-content: center;
  flex-wrap: wrap;
  font-size: 1rem;
}
.freed-trustbar-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-mute);
  margin-right: 8px;
}
.freed-trustbar-inner span {
  font-family: 'Fraunces', Georgia, serif;
  color: var(--ink-soft);
}
.freed-trustbar-dot { color: var(--ink-mute); font-size: 0.5rem; }

/* Thesis section */
.freed-thesis {
  padding: 80px 0;
}
.freed-thesis h2 {
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  color: var(--ink);
  margin-bottom: 14px;
}
.freed-thesis h2 em { font-style: italic; color: var(--stream); }
.freed-thesis-lede {
  font-size: 1.05rem;
  color: var(--ink-soft);
  line-height: 1.65;
  max-width: 640px;
  margin-bottom: 40px;
}
.freed-thesis-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
.freed-thesis-card {
  border-radius: 16px;
  padding: 32px;
  border: 1px solid var(--rule);
}
.freed-thesis-card--freed {
  background: var(--paper);
}
.freed-thesis-card--stream {
  background: var(--stream-light);
}
.freed-thesis-tag {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-mute);
  margin-bottom: 12px;
}
.freed-thesis-card h3 {
  font-size: 1.3rem;
  color: var(--ink);
  margin-bottom: 16px;
}
.freed-thesis-card h3 em { font-style: italic; color: var(--stream); }
.freed-thesis-card p {
  font-size: 0.925rem;
  color: var(--ink-soft);
  line-height: 1.6;
}
.freed-thesis-card strong { color: var(--ink); }

/* SOAP visual mock */
.soap-mock {
  margin-bottom: 20px;
  padding: 16px;
  background: rgba(15, 26, 20, 0.04);
  border-radius: 8px;
}
.soap-mock-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  color: var(--ink-mute);
  margin-bottom: 10px;
}
.soap-bar {
  height: 6px;
  border-radius: 3px;
  background: rgba(15, 26, 20, 0.12);
  margin-bottom: 5px;
}

/* Structured mock */
.struct-mock {
  margin-bottom: 20px;
}
.struct-section {
  padding: 8px 12px;
  background: rgba(15, 26, 20, 0.04);
  border-radius: 6px;
  margin-bottom: 6px;
}
.struct-section-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.58rem;
  letter-spacing: 0.08em;
  color: var(--ink-mute);
  margin-bottom: 4px;
}
.struct-problem {
  padding: 6px 10px;
  background: var(--stream-light);
  border-left: 3px solid var(--stream);
  border-radius: 4px;
  margin: 4px 0;
}
.struct-problem-name {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6rem;
  color: var(--stream);
  font-weight: 600;
}

/* Product tour */
.freed-tour {
  padding: 80px 0;
  background: var(--paper);
  border-top: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
}
.freed-tour h2 {
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  color: var(--ink);
  margin-bottom: 14px;
}
.freed-tour h2 em { font-style: italic; color: var(--stream); }
.freed-tour-lede {
  font-size: 1.05rem;
  color: var(--ink-soft);
  line-height: 1.65;
  max-width: 600px;
  margin-bottom: 40px;
}
.freed-tour-grid {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.freed-tour-pair {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
.freed-tour-card {
  background: var(--cream);
  border: 1px solid var(--rule);
  border-radius: 16px;
  overflow: hidden;
}
.freed-tour-card-visual {
  padding: 16px;
  background: var(--paper);
  border-bottom: 1px solid var(--rule);
}
.freed-tour-card-body {
  padding: 24px;
}
/* Full-width demo cards — horizontal split */
.freed-tour-card--wide {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
}
.freed-tour-card--wide .freed-tour-card-visual {
  border-bottom: none;
  border-right: 1px solid var(--rule);
  padding: 16px;
  display: flex;
  align-items: center;
}
.freed-tour-card--wide .freed-tour-card-body {
  padding: 40px;
  align-self: center;
}
/* Tour callouts */
.freed-tour-callouts {
  margin-top: 20px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.freed-tour-callout {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.72rem;
  color: var(--stream);
  letter-spacing: 0.02em;
}
.freed-tour-callout::before {
  content: '→ ';
  color: var(--accent);
}
/* Row 1 visual height match */
.freed-tour-pair .freed-tour-card-visual {
  min-height: 170px;
}
.freed-tour-card-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 10px;
}
.freed-tour-card h3 {
  font-size: 1.15rem;
  color: var(--ink);
  margin-bottom: 10px;
}
.freed-tour-card p {
  font-size: 0.9rem;
  color: var(--ink-soft);
  line-height: 1.6;
}

/* Scratchpad mock */
.scratchpad-mock {
  font-family: 'Fraunces', Georgia, serif;
  font-style: italic;
  font-size: 0.85rem;
  color: var(--ink-soft);
  padding: 16px;
  border: 2px dashed var(--rule);
  border-radius: 8px;
  margin-bottom: 12px;
  line-height: 1.5;
}
.scratchpad-arrow {
  text-align: center;
  color: var(--ink-mute);
  font-size: 1.2rem;
  margin: 8px 0;
}
.scratchpad-result {
  padding: 12px;
  background: var(--stream-light);
  border-radius: 6px;
  font-size: 0.75rem;
  color: var(--stream-dark);
}
.scratchpad-result-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.58rem;
  letter-spacing: 0.08em;
  color: var(--stream);
  margin-bottom: 4px;
}

/* Huddle mini mock (tour card) */
.huddle-mini {
  font-size: 0.72rem;
}
.huddle-mini-tabs {
  display: flex;
  gap: 4px;
  margin-bottom: 10px;
}
.huddle-mini-tab {
  padding: 4px 10px;
  border-radius: 100px;
  background: var(--paper-warm);
  color: var(--ink-mute);
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.58rem;
  letter-spacing: 0.05em;
}
.huddle-mini-tab--active {
  background: var(--stream-light);
  color: var(--stream);
}
.huddle-mini-row {
  padding: 8px 10px;
  border-bottom: 1px solid var(--rule);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.huddle-mini-name { font-weight: 600; color: var(--ink-soft); font-size: 0.72rem; }
.huddle-mini-meta { color: var(--ink-mute); font-size: 0.62rem; }

/* Comparison table */
.freed-compare {
  padding: 80px 0;
}
.freed-compare h2 {
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  color: var(--ink);
  margin-bottom: 14px;
}
.freed-compare h2 em { font-style: italic; color: var(--stream); }
.freed-compare-lede {
  font-size: 1rem;
  color: var(--ink-soft);
  line-height: 1.6;
  max-width: 640px;
  margin-bottom: 32px;
}
.freed-table-wrap {
  border: 1px solid var(--rule);
  border-radius: 16px;
  overflow: hidden;
  background: var(--cream);
}
.freed-table {
  width: 100%;
  border-collapse: collapse;
}
.freed-table thead {
  background: var(--stream-dark);
}
.freed-table th {
  padding: 14px 20px;
  text-align: left;
  font-family: 'Inter Tight', system-ui, sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--cream);
}
.freed-table th:nth-child(2) {
  border-top: 3px solid var(--accent);
  color: var(--accent-soft);
}
.freed-table th:nth-child(3) {
  color: rgba(250, 247, 240, 0.5);
}
.freed-table td {
  padding: 12px 20px;
  font-size: 0.875rem;
  border-bottom: 1px solid var(--rule);
  vertical-align: top;
}
.freed-table td:first-child {
  font-weight: 500;
  color: var(--ink);
}
.freed-table td:nth-child(2) {
  color: var(--stream);
  font-weight: 500;
}
.freed-table td:nth-child(3) {
  color: var(--ink-mute);
}
.freed-table-section {
  background: var(--paper);
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-mute);
}
.freed-table-section td {
  padding: 8px 20px;
  border-bottom: 1px solid var(--rule);
}
.freed-table-footnote {
  font-size: 0.78rem;
  color: var(--ink-mute);
  font-style: italic;
  text-align: center;
  margin-top: 16px;
}

/* Social proof */
.freed-proof {
  padding: 80px 0;
  background: var(--paper);
  border-top: 1px solid var(--rule);
}
.freed-proof h2 {
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  color: var(--ink);
  margin-bottom: 40px;
}
.freed-proof h2 em { font-style: italic; color: var(--stream); }
.freed-proof-grid {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 24px;
}
.freed-proof-feature {
  background: var(--cream);
  border: 1px solid var(--rule);
  border-radius: 16px;
  padding: 36px;
  position: relative;
}
.freed-proof-feature .freed-quote-mark {
  font-family: 'Fraunces', Georgia, serif;
  font-size: 4rem;
  color: var(--stream-light);
  line-height: 1;
  position: absolute;
  top: 20px;
  left: 28px;
}
.freed-proof-feature blockquote {
  font-family: 'Fraunces', Georgia, serif;
  font-size: 1.25rem;
  color: var(--ink);
  line-height: 1.5;
  margin: 24px 0 24px;
}
.freed-proof-attribution {
  display: flex;
  align-items: center;
  gap: 12px;
}
.freed-proof-avatar {
  width: 44px; height: 44px;
  border-radius: 50%;
  background: var(--stream-light);
  color: var(--stream);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.85rem;
  font-weight: 600;
  flex-shrink: 0;
}
.freed-proof-name { font-weight: 600; color: var(--ink); font-size: 0.9rem; }
.freed-proof-title { font-size: 0.78rem; color: var(--ink-mute); }
.freed-proof-stack {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.freed-proof-mini {
  background: var(--cream);
  border: 1px solid var(--rule);
  border-radius: 12px;
  padding: 20px;
}
.freed-proof-mini blockquote {
  font-family: 'Fraunces', Georgia, serif;
  font-size: 0.95rem;
  color: var(--ink);
  line-height: 1.5;
  margin-bottom: 10px;
  font-style: italic;
}
.freed-proof-mini-attr {
  font-size: 0.75rem;
  color: var(--ink-mute);
}

/* Switcher block */
.freed-switcher {
  padding: 80px 0;
  background: var(--paper-warm);
}
.freed-switcher-card {
  background: var(--stream-dark);
  border-radius: 20px;
  padding: 56px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  color: var(--cream);
}
.freed-switcher-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent-soft);
  margin-bottom: 16px;
}
.freed-switcher h2 {
  color: var(--cream);
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  margin-bottom: 16px;
}
.freed-switcher h2 em { font-style: italic; color: var(--accent-soft); }
.freed-switcher-body {
  font-size: 1rem;
  color: rgba(250, 247, 240, 0.65);
  line-height: 1.65;
  margin-bottom: 24px;
}
.freed-btn-accent {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--accent);
  color: var(--cream);
  padding: 12px 24px;
  border-radius: 100px;
  font-size: 0.9rem;
  font-weight: 600;
  text-decoration: none;
  transition: background 0.15s;
  font-family: 'Inter Tight', system-ui, sans-serif;
}
.freed-btn-accent:hover { background: var(--accent-soft); }
.freed-switcher-list {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.freed-switcher-item {
  display: flex;
  gap: 14px;
  align-items: flex-start;
}
.freed-switcher-check {
  width: 24px; height: 24px;
  border-radius: 50%;
  background: var(--stream);
  color: var(--cream);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  flex-shrink: 0;
  margin-top: 2px;
}
.freed-switcher-item strong {
  display: block;
  color: var(--cream);
  font-size: 0.95rem;
  margin-bottom: 4px;
}
.freed-switcher-item p {
  font-size: 0.85rem;
  color: rgba(250, 247, 240, 0.55);
  line-height: 1.5;
}

/* Pricing */
.freed-pricing {
  padding: 80px 0;
}
.freed-pricing h2 {
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  color: var(--ink);
  margin-bottom: 14px;
  text-align: center;
}
