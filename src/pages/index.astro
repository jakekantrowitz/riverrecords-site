  // Step 1 — Waveform
  StreamWidgets.WaveformWidget('#step-waveform', { autoStart: true });

  // Step 2 — Problem list (same data, interactive)
  StreamWidgets.ProblemListWidget('#step-problem-list', {
    problems: [
      { name: "Type 2 Diabetes Mellitus", status: "Active",   encounters: 14, icd: "E11.65" },
      { name: "Essential Hypertension",   status: "Active",   encounters: 11, icd: "I10"    },
      { name: "Hyperlipidemia",           status: "Stable",   encounters: 8,  icd: "E78.5"  },
      { name: "Seasonal Allergic Rhinitis",status:"Resolved", encounters: 2,  icd: "J30.2"  },
    ]
  });

  // Step 3 — Task list (interactive checkboxes)
  StreamWidgets.TaskListWidget('#step-task-list');

  // Step 4 — Problem summary card
  StreamWidgets.ProblemSummaryCard('#step-problem-summary');

});
</script>

